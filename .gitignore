# --- Node / frontend ---
node_modules/

# Vite build output (embedded via go:embed; regenerated by `npm run build`).
# Keep a placeholder so `go build` compiles on a fresh clone.
web/dist/
!web/dist/.gitkeep

# TypeScript incremental build cache + `tsc -b` emitted config artifacts
# (the source is vite.config.ts; the .js/.d.ts are generated).
web/*.tsbuildinfo
web/vite.config.js
web/vite.config.d.ts

# --- Rust (PoC) ---
rust-poc/target/

# --- Go build output ---
/sony-camera-portal
/sony-camera-portal-ish
/dist/
*.test

# --- Camera capture: keep the *.xml fixtures, ignore run logs ---
camera/testdata/*.log

# --- Dev artifacts ---
docs/ui-mock.png

# --- Local / machine-specific ---
.claude/settings.local.json

# --- OS / editor ---
.DS_Store
*.swp
